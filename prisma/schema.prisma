generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model users {
  id                            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                          String
  bio                           String?
  email_personal                String?
  email_institutional           String?
  phone                         String
  profile_image_url             String?
  resale_whatsapp               String?
  resale_instagram              String?
  resale_telegram               String?
  password_hash                 String
  role                          user_role          @default(public)
  created_at                    DateTime           @default(now()) @db.Timestamptz(6)
  email_institutional_verified  Boolean            @default(false)
  verification_token            String?
  verification_token_expires_at DateTime?          @db.Timestamptz(6)
  event_presence                event_presence[]
  events                        events[]
  republic_invites_sent         republic_invites[] @relation("invited_by")
  republic_invites_received     republic_invites[] @relation("invited_user")
  republic_members              republic_members[]
  resale_reviews                resale_reviews[]
  resales                       resales[]

  @@map("users")
}

model republics {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  city             String
  instagram        String
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  events           events[]
  republic_invites republic_invites[]
  republic_members republic_members[]

  @@map("republics")
}

model republic_members {
  user_id     String      @db.Uuid
  republic_id String      @db.Uuid
  role        member_role @default(member)
  republic    republics   @relation(fields: [republic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, republic_id])
  @@map("republic_members")
}

model republic_invites {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  republic_id        String        @db.Uuid
  invited_user_id    String        @db.Uuid
  invited_by_user_id String        @db.Uuid
  status             invite_status @default(pending)
  created_at         DateTime      @default(now()) @db.Timestamptz(6)
  invited_by_user    users         @relation("invited_by", fields: [invited_by_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invited_user       users         @relation("invited_user", fields: [invited_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  republic           republics     @relation(fields: [republic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("republic_invites")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model events {
  id                     String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String
  description            String?
  image_url              String?
  date                   DateTime          @db.Timestamptz(6)
  ended_at               DateTime          @db.Timestamptz(6)
  created_by_user_id     String            @db.Uuid
  created_by_republic_id String?           @db.Uuid
  ticket_platform        String?
  ticket_url             String?
  instagram              String?
  visibility_type        visibility_type   @default(public)
  created_at             DateTime          @default(now()) @db.Timestamptz(6)
  event_location         event_location?
  event_lots             event_lots[]
  event_presence         event_presence[]
  event_promoters        event_promoters[]
  created_by_republic    republics?        @relation(fields: [created_by_republic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  created_by_user        users             @relation(fields: [created_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resales                resales[]

  @@map("events")
}

model event_location {
  event_id   String    @id @db.Uuid
  latitude   Decimal   @db.Decimal(9, 6)
  longitude  Decimal   @db.Decimal(9, 6)
  address    String?
  release_at DateTime? @db.Timestamptz(6)
  event      events    @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("event_location")
}

model event_promoters {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id  String  @db.Uuid
  name      String
  whatsapp  String?
  instagram String?
  telegram  String?
  event     events  @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([event_id, instagram], map: "uq_event_promoters_instagram")
  @@unique([event_id, telegram], map: "uq_event_promoters_telegram")
  @@unique([event_id, whatsapp], map: "uq_event_promoters_whatsapp")
  @@map("event_promoters")
}

model event_lots {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id   String    @db.Uuid
  lot_number Int
  price      Decimal   @db.Decimal(10, 2)
  start_date DateTime  @db.Timestamptz(6)
  end_date   DateTime? @db.Timestamptz(6)
  active     Boolean   @default(false)
  event      events    @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([event_id, lot_number])
  @@map("event_lots")
}

model event_presence {
  event_id String          @db.Uuid
  user_id  String          @db.Uuid
  status   presence_status @default(confirmed)
  event    events          @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user     users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([event_id, user_id])
  @@map("event_presence")
}

model resales {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String           @db.Uuid
  event_id       String           @db.Uuid
  price          Decimal          @db.Decimal(10, 2)
  quantity       Int
  status         resale_status    @default(open)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  resale_reviews resale_reviews[]
  event          events           @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("resales")
}

model resale_reviews {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewer_user_id String   @db.Uuid
  resale_id        String   @db.Uuid
  rating           Int      @db.SmallInt
  comment          String?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  resale           resales  @relation(fields: [resale_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reviewer         users    @relation(fields: [reviewer_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([reviewer_user_id, resale_id])
  @@map("resale_reviews")
}

enum user_role {
  public
  institutional
  admin
}

enum member_role {
  member
  admin
  aggregate
}

enum invite_status {
  pending
  accepted
  rejected
}

enum visibility_type {
  public
  institutional_only
  private
}

enum presence_status {
  confirmed
  cancelled
  maybe
}

enum resale_status {
  open
  sold
  cancelled
}
